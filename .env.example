DODO_PRODUCT_ID=pdt_0NfBt7eUi120qMFvjJLCu
DODO_API_BASE=https://api.dodopayments.com        # Optional override

# Public — exposed to the browser. Use a Dodo "buy link" if you have one; otherwise
